digraph FSM {
  rankdir=LR;
  node [shape=circle fontsize=12];
  S0 [shape=doublecircle label="S0\nout=0"];
  S1 [shape=circle label="S1\nout=0"];
  S2 [shape=circle label="S2\nout=0"];
  S3 [shape=circle label="S3\nout=0"];
  S4 [shape=circle label="S4\nout=1"];
  S0 -> S1 [label="0"];
  S0 -> S0 [label="1"];
  S1 -> S1 [label="0"];
  S1 -> S2 [label="1"];
  S2 -> S3 [label="0"];
  S2 -> S0 [label="1"];
  S3 -> S1 [label="0"];
  S3 -> S4 [label="1"];
  S4 -> S3 [label="0"];
  S4 -> S0 [label="1"];
}